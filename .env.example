# ─────────────────────────────────────────────────────────────────────────────
# 0% Gold Shop POS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase Client SDK (safe to expose — restricted by Firebase rules) ──────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (SERVER ONLY — never prefix with NEXT_PUBLIC_) ────────
# Generate a service account key from:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private key with literal \n for newlines, wrapped in double quotes:
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Cloud Functions bootstrap (only needed once during initial setup) ─────────
# Set a random secret string, then call bootstrapSuperAdmin with it.
# Delete or leave blank after the first super admin is created.
BOOTSTRAP_SECRET=
# Password for alwazer@admin.com — used only once during bootstrap, then ignored.
SUPER_ADMIN_PASSWORD=
